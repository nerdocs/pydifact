    <data_element id="0085" name="SyntaxErrorCoded" repetition="1" type="an" maxlength="3"/>
    <data_element id="0013" name="ServiceSegmentTagCoded" repetition="1" type="a" maxlength="3"/>
    <composite_data_element id="S011" name="DataElementIdentification" repetition="1"/>
  </segment>
  <segment id="UCM" name="MessageResponse" desc="To identify a message in the subject interchange, and to indicate that message's acknowledgement or rejection (action taken), and to identify any error related to the UNH and UNT segments.">
    <data_element id="0062" name="MessageReferenceNumber" required="true" repetition="1" type="an" maxlength="14"/>
